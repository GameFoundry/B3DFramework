diff --git a/Makefile.osx b/Makefile.osx
index c39121d..7d904f2 100644
--- a/Makefile.osx
+++ b/Makefile.osx
@@ -8,6 +8,8 @@ include Makefile.srcs
 MACOSX_SYSROOT = $(shell xcrun --show-sdk-path)
 # Specify deployement target here
 MACOSX_DEPLOYMENT_TARGET = 10.11
+# Build for the host architecture (arm64 on Apple Silicon, x86_64 on Intel)
+MACOSX_ARCH = $(shell uname -m)
 
 # General configuration variables:
 CC_I386 = $(shell xcrun -find clang)
@@ -15,9 +17,15 @@ CC_X86_64 = $(shell xcrun -find clang)
 CPP_I386 = $(shell xcrun -find clang++)
 CPP_X86_64 = $(shell xcrun -find clang++)
 MACOSX_DEPLOY = -mmacosx-version-min=$(MACOSX_DEPLOYMENT_TARGET)
-COMPILERFLAGS = -Os -fexceptions -fvisibility=hidden -DNO_LCMS -D__ANSI__
+# Z_HAVE_UNISTD_H: modern clang doesn't define the legacy `unix` macro, so bundled
+# ZLib needs to be told explicitly that <unistd.h> exists (lseek/read/write/close).
+# DISABLE_PERF_MEASUREMENT: matches Makefile.gnu; LibJXR's PerfTimer implementation
+# is not part of the source list, so calls to it would fail to link.
+# PNG_ARM_NEON_OPT=0: bundled LibPNG doesn't ship its arm/ NEON sources, so the
+# NEON code path it auto-enables on arm64 must be turned off.
+COMPILERFLAGS = -Os -fexceptions -fvisibility=hidden -DNO_LCMS -D__ANSI__ -DZ_HAVE_UNISTD_H -DDISABLE_PERF_MEASUREMENT -DPNG_ARM_NEON_OPT=0
 COMPILERFLAGS_I386 = -arch i386
-COMPILERFLAGS_X86_64 = -arch x86_64
+COMPILERFLAGS_X86_64 = -arch $(MACOSX_ARCH)
 COMPILERPPFLAGS = -Wno-ctor-dtor-privacy -D__ANSI__ -std=c++11 -stdlib=libc++ -Wc++11-narrowing
 INCLUDE +=
 INCLUDE_I386 = -isysroot $(MACOSX_SYSROOT)
@@ -82,7 +90,7 @@ $(STATICLIB)-i386: $(MODULES_I386)
 	$(LIBTOOL) -arch_only i386 -o $@ $(MODULES_I386)
 
 $(STATICLIB)-x86_64: $(MODULES_X86_64)
-	$(LIBTOOL) -arch_only x86_64 -o $@ $(MODULES_X86_64)
+	$(LIBTOOL) -arch_only $(MACOSX_ARCH) -o $@ $(MODULES_X86_64)
 
 $(SHAREDLIB): $(SHAREDLIB)-i386 $(SHAREDLIB)-x86_64
 	$(LIPO) -create $(SHAREDLIB)-i386 $(SHAREDLIB)-x86_64 -output $(SHAREDLIB)
